# Copy to .env and adjust.
NODE_ENV=development
PORT=5000

# MongoDB. For ACID transactions (points + wallet) use a replica set or Atlas.
# Standalone mongod also works — the backend falls back to non-transactional writes.
MONGO_URI=mongodb://127.0.0.1:27017/jain_patashala

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=30d

# Comma-separated list of allowed frontend origins (CORS)
CLIENT_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:8081

# Platform defaults
POINT_TO_RUPEE=1
